# ============================================================
# FICHA DE PROFESIONALES - Variables de Entorno
# ============================================================
# INSTRUCCIONES:
#   1. Copia este archivo como ".env" en la carpeta /backend
#   2. Rellena cada valor según tu entorno
#   3. NUNCA subas el archivo .env a Git (ya está en .gitignore)
# ============================================================

# ------------------------------------------------------------
# BASE DE DATOS PostgreSQL 16
# ------------------------------------------------------------
DB_HOST=localhost          # Host del servidor PostgreSQL
DB_PORT=5432               # Puerto (por defecto 5432)
DB_NAME=ficha_profesionales # Nombre de la base de datos
DB_USER=postgres           # Usuario de PostgreSQL
DB_PASSWORD=tu_password_aqui # Contraseña del usuario
DB_POOL_MAX=10             # Máximo de conexiones en el pool
DB_POOL_IDLE=30000         # Tiempo máximo inactivo (ms)
DB_POOL_ACQUIRE=60000      # Tiempo máximo para adquirir conexión (ms)

# ------------------------------------------------------------
# ANTHROPIC - Claude API
# ------------------------------------------------------------
# Cómo obtener tu API Key:
#   1. Ingresa a https://console.anthropic.com
#   2. Ve a "API Keys" en el menú lateral
#   3. Haz clic en "Create Key"
#   4. Copia la clave generada (solo se muestra una vez)
#   5. Pégala aquí después del signo =
# IMPORTANTE: La clave comienza con "sk-ant-..."
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Modelo a utilizar (se recomienda claude-opus-4-5 para mayor precisión)
CLAUDE_MODEL=claude-opus-4-5

# Máximo de tokens en la respuesta de Claude (4000 es suficiente para CVs)
CLAUDE_MAX_TOKENS=4000

# ------------------------------------------------------------
# OPENAI - Embeddings para RAG (búsqueda en lenguaje natural)
# ------------------------------------------------------------
# Necesario para indexar CVs y buscar en lenguaje natural.
# Obtén tu API Key en https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Modelo de embeddings (1536 dimensiones)
EMBEDDING_MODEL=text-embedding-3-small
# Cantidad de fragmentos a recuperar por consulta RAG
RAG_TOP_K=5

# ------------------------------------------------------------
# OLLAMA - Procesamiento local (alternativa a Anthropic)
# ------------------------------------------------------------
# URL base del servidor Ollama (por defecto http://localhost:11434)
OLLAMA_BASE_URL=http://localhost:11434
# Modelo a usar (debe estar descargado con: ollama pull llama3.2)
OLLAMA_MODEL=llama3.2

# ------------------------------------------------------------
# SERVIDOR EXPRESS
# ------------------------------------------------------------
PORT=3001                  # Puerto del servidor backend
NODE_ENV=development       # Entorno: development | production

# ------------------------------------------------------------
# ALMACENAMIENTO DE ARCHIVOS (sistema local)
# ------------------------------------------------------------
# Ruta donde se guardarán los PDFs subidos
# En Windows usa: C:/ficha-profesionales/uploads
# En Linux/Mac usa: /var/app/uploads  o  ./uploads
UPLOADS_PATH=./uploads

# Tamaño máximo permitido por archivo PDF (en bytes)
# 10485760 = 10 MB
MAX_FILE_SIZE=10485760

# ------------------------------------------------------------
# CORS - Orígenes permitidos para el frontend
# ------------------------------------------------------------
# En desarrollo: URL del servidor React (puerto 3000 por defecto)
# En producción: URL real del frontend
CORS_ORIGIN=http://localhost:3000

# ------------------------------------------------------------
# SEGURIDAD (opcional, para producción)
# ------------------------------------------------------------
# JWT_SECRET=cambia_este_valor_en_produccion
# JWT_EXPIRES_IN=8h
